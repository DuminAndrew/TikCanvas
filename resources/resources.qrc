<RCC>
    <qresource prefix="/styles">
        <file alias="dark.qss">dark.qss</file>
        <file alias="light.qss">light.qss</file>
    </qresource>
    <qresource prefix="/icons">
        <file alias="app.svg">../icon.svg</file>
    </qresource>
    <qresource prefix="/i18n">
        <file alias="tikcanvas_ru.qm">i18n/tikcanvas_ru.qm</file>
        <file alias="tikcanvas_en.qm">i18n/tikcanvas_en.qm</file>
    </qresource>
</RCC>
